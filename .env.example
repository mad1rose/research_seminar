# Copy to `.env` and adjust. Never commit `.env` with real secrets.
# Used by docker compose (`env_file`) and optional local tooling.

# Required for any shared or public deployment (Flask sessions).
SECRET_KEY=change-me-to-a-long-random-string

# Web server (see app.py)
PORT=5000
# Bind address: use 0.0.0.0 inside Docker so the host can reach the app.
FLASK_HOST=0.0.0.0
# 1/true/yes = Flask debug; 0/false/no = production-style
FLASK_DEBUG=0

# Optional: path to tessituragram library JSON (default: data/all_tessituragrams.json)
# TESSITURAGRAM_LIBRARY_PATH=/app/data/all_tessituragrams.json
